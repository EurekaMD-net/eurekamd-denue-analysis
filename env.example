# Token de acceso a la API DENUE (INEGI)
# Solicitar en: https://www.inegi.org.mx/app/api/denue/v1/tokenVerify.aspx
DENUE_TOKEN=your-token-here

# Conexión a base de datos Supabase
SUPABASE_URL=http://localhost:8100
SUPABASE_SERVICE_KEY=your_service_role_jwt_here

# Fase 5 — HTTP API
# REQUERIDO: clave que clientes deben enviar en el header X-Api-Key.
# El servidor falla al arrancar si esta variable está vacía.
API_KEY=generate-with-openssl-rand-base64-32

# Opcionales (tienen defaults)
# API_PORT=3030                # puerto de escucha del servidor HTTP
# SUPABASE_DB_CONTAINER=supabase-db  # contenedor docker de Postgres
# OUTPUT_DIR=./data/raw        # JSON extraídos por estado
# STATE_DIR=./data/state       # pipeline-state.json (separado de OUTPUT_DIR)
